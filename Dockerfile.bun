# Build the package with the canonical toolchain (node + tsc) ...
FROM node:24-slim AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm clean-install
COPY . .
RUN npm run dist

# ... then run the bun:test matchers (source) and the smoke (built artifact) on bun.
FROM oven/bun:1
WORKDIR /app
COPY --from=build /app/package.json ./
COPY --from=build /app/src ./src
COPY --from=build /app/bun ./bun
COPY --from=build /app/dist ./dist
COPY --from=build /app/smoke.mjs ./
