{
  "name": "@potentia/util",
  "version": "4.1.0",
  "description": "cross-runtime utilities for node.js, bun and deno",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "sideEffects": [
    "./bigint-json.js",
    "./patch/**/*.js"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "dist": "tsc",
    "dist:release": "tsc --sourceMap false",
    "lint": "eslint --fix .",
    "pretty": "prettier --write .",
    "fix": "npm run lint && npm run pretty",
    "test": "npm run dist && npm run test:node && npm run test:jest && npm run test:vitest && npm run smoke",
    "test:node": "node --test --experimental-test-coverage 'dist/test/**/*.js'",
    "test:bun": "bun test ./bun",
    "test:deno": "deno test --allow-net --allow-read 'dist/test/**/*.js'",
    "test:jest": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:vitest": "vitest run",
    "smoke": "node smoke.mjs",
    "smoke:bun": "bun smoke.mjs",
    "smoke:deno": "deno run -A smoke.mjs"
  },
  "author": "Potentia Computing Inc.",
  "license": "MIT",
  "devDependencies": {
    "@tsconfig/node24": "^24.0.0",
    "@types/bun": "^1.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-jest": "^29.0.0",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./bigint-json": {
      "types": "./bigint-json.d.ts",
      "default": "./bigint-json.js"
    },
    "./patch": {
      "types": "./patch/index.d.ts",
      "default": "./patch/index.js"
    },
    "./patch/bigint": {
      "types": "./patch/bigint/index.d.ts",
      "default": "./patch/bigint/index.js"
    },
    "./patch/bigint/json": {
      "types": "./patch/bigint/json.d.ts",
      "default": "./patch/bigint/json.js"
    },
    "./abort-controller": {
      "types": "./abort-controller.d.ts",
      "default": "./abort-controller.js"
    },
    "./dispatcher": {
      "types": "./dispatcher.d.ts",
      "default": "./dispatcher.js"
    },
    "./duration": {
      "types": "./duration.d.ts",
      "default": "./duration.js"
    },
    "./logger": {
      "types": "./logger.d.ts",
      "default": "./logger.js"
    },
    "./error": {
      "types": "./error.d.ts",
      "default": "./error.js"
    },
    "./misc": {
      "types": "./misc.d.ts",
      "default": "./misc.js"
    },
    "./promise": {
      "types": "./promise.d.ts",
      "default": "./promise.js"
    },
    "./fetch": {
      "types": "./fetch.d.ts",
      "default": "./fetch.js"
    },
    "./signature": {
      "types": "./signature.d.ts",
      "default": "./signature.js"
    },
    "./type": {
      "types": "./type.d.ts",
      "default": "./type.js"
    },
    "./matcher/jest": {
      "types": "./matcher/jest.d.ts",
      "default": "./matcher/jest.js"
    },
    "./matcher/bun": {
      "types": "./matcher/bun.d.ts",
      "default": "./matcher/bun.js"
    },
    "./matcher/vitest": {
      "types": "./matcher/vitest.d.ts",
      "default": "./matcher/vitest.js"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
