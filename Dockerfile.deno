# Build the package with the canonical toolchain (node + tsc) ...
FROM node:24-slim AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm clean-install
COPY . .
RUN npm run dist

# ... then run the node:test suite and the smoke (both the built artifact) on deno.
FROM denoland/deno:latest
WORKDIR /app
COPY --from=build /app/package.json ./
COPY --from=build /app/dist ./dist
COPY --from=build /app/smoke.mjs ./
